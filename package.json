{
  "name": "react-json-component",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsup src/index.ts src/converters.ts --format cjs,esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "prepack": "npm run build"
  },
  "peerDependencies": {
    "immer": "^10.0.0 || ^11.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "zustand": "^4.0.0 || ^5.0.0"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/types": "^7.29.0",
    "@testing-library/react": "^16.0.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "immer": "^11.1.4",
    "jsdom": "^25.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./converters": {
      "types": "./dist/converters.d.ts",
      "import": "./dist/converters.mjs",
      "require": "./dist/converters.js"
    }
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
